---
import { Image } from 'astro:assets';
import Meeting from '../assets/Meeting.jpg'
import Button from './Button.astro'
---


<section class="hero">
    <div class="container">
        <h1>Take control of your finances with confidence</h1>
        <p>We handle the numbers so you can focus on growing your business.</p>
        <div class="button-group">
            <Button href="#" variant="primary">Get in touch</Button>
            <Button href="#" variant="secondary">View our services</Button>
        </div>
     </div>
    </div>
    <div class="hero-overlay"></div>
    <Image src={Meeting} alt="People meeting in an office" loading="eager" fetchpriority="high" decoding="sync">
    
</section>


<style>
.hero {
    height: 100vh;
    position: relative;
    }

.container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    row-gap: 1.5rem;
}

.button-group {
    display: flex;
    column-gap: 1rem;
}

img {
    position: absolute;
    width: 100%;
    height: 100%;
    z-index: -2;
    inset: 0;
    object-fit: cover;
}

.hero-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    z-index: -1;
    inset: 0;
    background: rgba(10, 10, 10, 0.80);
}

h1 {
    color: white;
    font-size: 4rem;
    text-align: center;
}

p {
    color: rgba(255, 255, 255, 0.833);
}

</style>