---
import '@fontsource/noto-sans/400.css'; // Regular
import '@fontsource/noto-sans/600.css'; // Semi Bold
import '@fontsource/noto-sans/700.css'; // Bold
import Header from '../components/Header.astro'

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/Logo.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
		<Header />
		<slot />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Noto Sans', sans-serif;
	}

	*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box; /* This keeps padding from making elements wider than 100% */
  }

  h1 {
	font-weight: 700;
	line-height: 1em;
  }

	section {
		padding: 3rem 1.5rem;
	}
	.container {
		width: 100%;
		max-width: 1400px;
	}
</style>
